{
  "name": "anime-radar",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "import:anime": "tsx scripts/update-anime.ts",
    "update:anime": "tsx scripts/update-anime.ts",
    "update:anime:write": "tsx scripts/update-anime.ts --write",
    "discover:anilist": "tsx scripts/update-anime.ts --source anilist --discover --dry-run"
  },
  "dependencies": {
    "next": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "tailwindcss": "^3.4.17",
    "tsx": "latest",
    "typescript": "latest",
    "postcss": "latest",
    "autoprefixer": "latest"
  }
}
